# mock: runs immediately without cloud credentials; huaweicloud: calls the real IoTDA API.
IOTDA_MODE=mock
PORT=3001
WEB_ORIGIN=http://localhost:5173

# IoTDA application-side HTTPS access information. Obtain it from IoTDA Console > Overview > Access Information.
IOTDA_ENDPOINT=https://iotda.cn-north-4.myhuaweicloud.com
IOTDA_PROJECT_ID=replace-with-project-id
IOTDA_INSTANCE_ID=
IOTDA_SERVICE_ID=smartRoom
IOTDA_LIGHT_COMMAND_NAME=Light
IOTDA_MODE_COMMAND_NAME=CtlMode

# IAM password authentication is server-side only. Never use these variables in the web app.
HUAWEICLOUD_IAM_ENDPOINT=https://iam.cn-north-4.myhuaweicloud.com
HUAWEICLOUD_IAM_USERNAME=
HUAWEICLOUD_IAM_PASSWORD=
HUAWEICLOUD_IAM_DOMAIN=
HUAWEICLOUD_IAM_PROJECT=cn-north-4

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=54321
DB_DATABASE=test
DB_USER=system
DB_PASSWORD=123456